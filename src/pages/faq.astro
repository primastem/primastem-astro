---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import FAQ from '../components/blocks/FAQ/FaqSticky.astro'
import TextImage from '../components/blocks/basic/TextImage.astro'

// Data
import faqData from '../data/json-files/faqData.json'
const faqProduct = faqData.filter((faq) => faq.category === 'product')
const faqPricing = faqData.filter((faq) => faq.category === 'pricing')
const faqTechnical = faqData.filter((faq) => faq.category === 'technical')

// Content
import faqImage1 from '../assets/faq/faq-01.png'
// - SEO
const SEO = {
	title: 'PrimaSTEM | Frequently Asked Questions',
	description:
		'Find answers to common questions about PrimaSTEM — pricing, product features, compatibility, and how to get started with our screen-free educational robot.'
}
const header = {
	title: 'Frequently Asked <strong>Questions</strong>',
	text: 'Find answers to common questions about PrimaSTEM'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<FAQ
		title="Product"
		text="How PrimaSTEM works, what's included, and what it can do."
		data={faqProduct}
	/>
	<FAQ
		title="Pricing & Availability"
		text="Costs, ordering options, and distributors."
		data={faqPricing}
	/>
	<FAQ
		title="Technical"
		text="Battery, safety, customization, and accessibility."
		data={faqTechnical}
	/>
	<TextImage
		title="Why PrimaSTEM Offers Great Value"
		text="One purchase — lasts through primary school. Two learning levels in one device. No subscriptions, no apps, no hidden costs. Complete kit with lesson plans and teacher's guide included."
		image={faqImage1}
		mobileImage={faqImage1}
		imagePosition="left"
		offsetImage
		classes="bg-neutral-50 dark:bg-neutral-900 lg:!py-64"
	/>
</Layout>
