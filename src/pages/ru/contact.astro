---
// Components
import Layout from '../../layouts/Layout.astro'
import FormHero from '../../components/blocks/hero/ContactHero.astro'

// Content (CMS-editable)
import pageData from '../../content/pages/ru/contact.json'

const { seo, hero, contactItems } = pageData
---

<Layout title={seo.title} description={seo.description}>
	<FormHero
		title={hero.title}
		text={hero.text}
		id="contact"
		classes="bg-neutral-50 dark:bg-neutral-950/80"
	>
		<ul class="mt-6 space-y-2 text-base text-neutral-600 dark:text-neutral-400 list-none">
			{
				contactItems.map((item) => (
					<li>
						<strong>{item.label}</strong>
						{item.href ? (
							item.external ? (
								<>
									{' '}
									<a href={item.href} class="text-primary-500 hover:underline" target="_blank" rel="noopener noreferrer">
										{item.value}
									</a>
								</>
							) : (
								<>
									{' '}
									<a href={item.href} class="text-primary-500 hover:underline">
										{item.value}
									</a>
								</>
							)
						) : (
							<> {item.value}</>
						)}
					</li>
				))
			}
		</ul>
		<div slot="form">
			<div class="overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-700">
				<iframe
					title="PrimaSTEM - Cannes, France"
					src="https://maps.google.com/maps?q=Cannes,France&amp;ll=50,9&amp;z=4&amp;output=embed"
					width="100%"
					height="450"
					style="border:0; display:block;"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					allowfullscreen
				></iframe>
			</div>
		</div>
	</FormHero>
</Layout>
