---
// Components
import Layout from '../layouts/Layout.astro'
import Section from '../components/ui/Section.astro'
import Row from '../components/ui/Row.astro'
import Col from '../components/ui/Col.astro'
import { Image } from 'astro:assets'
import Button from '../components/ui/Button.astro'
import SidebarContent from '../components/blocks/basic/StickySidebar.astro'
import ContactCTA from '../components/blocks/CTA/ContactCTA.astro'

// Asset
import heroImage from '../assets/board-3d.jpg'

// Content (CMS-editable)
import { marked } from 'marked'
import pageData from '../content/en/pages/distributors.json'

const { seo, hero, sections, cta } = pageData
---

<Layout title={seo.title} description={seo.description}>
	<!-- HERO -->
	<Section id="distributors-hero" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
		<Row>
			<Col span="6" align="start">
				<h1 set:html={hero.title} />
				<p class="text-lg">{hero.subtitle1}</p>
				<p class="text-lg">{hero.subtitle2}</p>
				<p class="text-xl font-bold">{hero.price}</p>
				<p set:html={hero.volumeLine} />
				<div class="flex gap-4 flex-wrap">
					{
						hero.buttons.map((btn) => (
							<Button size="lg" style={btn.style as 'primary' | 'secondary' | 'neutral'} link={btn.link}>
								{btn.text}
							</Button>
						))
					}
				</div>
			</Col>
			<Col span="6">
				<Image
					src={heroImage}
					alt="PrimaSTEM complete kit"
					class="rounded-xl"
					format="webp"
					loading="eager"
				/>
			</Col>
		</Row>
	</Section>

	{
		sections.map((section, idx) => (
			<SidebarContent classes={idx % 2 === 1 ? 'bg-neutral-50 dark:bg-neutral-900' : ''}>
				<div slot="sidebar">
					<h3>{section.sidebarTitle}</h3>
					{section.sidebarText && <p>{section.sidebarText}</p>}
				</div>
				<div class="basic-text" set:html={marked.parse(section.body)} />
			</SidebarContent>
		))
	}

	<ContactCTA title={cta.title} subtitle={cta.subtitle} buttonText={cta.buttonText} />
</Layout>
