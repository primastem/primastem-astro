---
// Home page Hero Section
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Image } from 'astro:assets'
import Button from '../../ui/Button.astro'

import heroImage from '../../../assets/hero-primastem.jpg'

type Props = {
	data: {
		title: string
		subtitle: string
		price: string
		volumeLine: string
		buttonText: string
		buttonLink: string
	}
}

const { data } = Astro.props
---

<Section id="intro" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="6" align="start">
			<h1 set:html={data.title} />
			<p class="text-lg" set:html={data.subtitle} />
			<p class="text-xl font-bold">{data.price}</p>
			<p set:html={data.volumeLine} />
			<Button size="lg" link={data.buttonLink}>{data.buttonText}</Button>
		</Col>
		<Col span="6">
			<Image
				src={heroImage}
				alt="PrimaSTEM complete kit: wooden control board with colorful command tokens, ladybug robot, and drawings made by the robot"
				class="rounded-xl"
				format="webp"
				loading="eager"
			/>
		</Col>
	</Row>
</Section>
