---
// Home page Hero Section
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Button from '../../ui/Button.astro'

// hero-primastem.jpg still used on /product and the product sheet — kept in repo.

type Props = {
	data: {
		title: string
		subtitle: string
		price: string
		volumeLine: string
		buttonText: string
		buttonLink: string
	}
}

const { data } = Astro.props
---

<Section id="intro" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="6" align="start">
			<h1 set:html={data.title} />
			<p class="text-lg" set:html={data.subtitle} />
			<p class="text-xl font-bold">{data.price}</p>
			<p set:html={data.volumeLine} />
			<Button size="lg" link={data.buttonLink}>{data.buttonText}</Button>
		</Col>
		<Col span="6">
			<div class="flex justify-center">
				<div class="relative w-full max-w-[300px] aspect-[9/16] overflow-hidden rounded-xl">
					<iframe
						class="absolute inset-0 h-full w-full"
						src="https://www.youtube-nocookie.com/embed/cr27t8_W4qo?autoplay=1&mute=1&loop=1&playlist=cr27t8_W4qo&playsinline=1&rel=0&modestbranding=1"
						title="PrimaSTEM in action"
						loading="eager"
						allow="accelerated-sensors; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
						allowfullscreen
					></iframe>
				</div>
			</div>
		</Col>
	</Row>
</Section>
