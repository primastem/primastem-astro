---
// Home page Hero Section
// ------------
// Description: Two-column hero with text on left, product image on right.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import { Image } from 'astro:assets'
import Button from '../../ui/Button.astro'

// Content
import heroImage from '../../../assets/hero-primastem.jpg'
---

<Section id="intro" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="6" align="start">
			<h1>Coding and math <strong>without a screen.</strong></h1>
			<p class="text-lg">
				The only screen-free tool that teaches both.<br />
				Ages 4 to 10.
			</p>
			<p class="text-xl font-bold">From €235 excl. VAT.</p>
			<Button size="lg" link="#pricing-v3">See pricing</Button>
		</Col>
		<Col span="6">
			<Image
				src={heroImage}
				alt="PrimaSTEM complete kit: wooden control board with colorful command tokens, ladybug robot, and drawings made by the robot"
				class="rounded-xl"
				format="webp"
				loading="eager"
			/>
		</Col>
	</Row>
</Section>
