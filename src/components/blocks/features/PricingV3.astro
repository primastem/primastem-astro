---
// Pricing Section V3 — using original PricingTable component
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import PricingTable from '../../ui/pricing-tables/PricingTable.astro'

import pricingEn from '../../../content/pricing/en.json'
import pricingFr from '../../../content/pricing/fr.json'
import pricingDe from '../../../content/pricing/de.json'
import pricingEs from '../../../content/pricing/es.json'
import pricingRu from '../../../content/pricing/ru.json'

const pricingByLocale: Record<string, typeof pricingEn> = { en: pricingEn, fr: pricingFr, de: pricingDe, es: pricingEs, ru: pricingRu }
const locale = Astro.currentLocale ?? 'en'
const pricingDataRaw = pricingByLocale[locale] ?? pricingEn
const prefix = locale === 'en' ? '' : `/${locale}`

const pricingData = pricingDataRaw.items.map((item) => ({
	...item,
	type: item.type as 'basic' | 'featured',
	header: { ...item.header, buttonLink: `${prefix}${item.header.buttonLink}` }
}))
---

<Section id="pricing-v3" padding="both">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 set:html={pricingDataRaw.sectionTitle} />
			<p class="pb-0 text-lg">{pricingDataRaw.sectionSubtitle}</p>
			{pricingDataRaw.simulatorNote && <p class="pb-0 mt-2 text-sm text-neutral-500 dark:text-neutral-400" set:html={pricingDataRaw.simulatorNote} />}
		</Col>
	</Row>
	<Row>
		{pricingData.map((item, key) => (
			<Col span="4">
				<PricingTable data={item} listType="checklist" id={`plan-${key}`} />
			</Col>
		))}
	</Row>
</Section>
