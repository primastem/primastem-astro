---
// Two Levels Section
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Image } from 'astro:assets'

import logicImg from '../../../assets/maps-on-grid.jpg'
import mathImg from '../../../assets/robot-drawing.jpg'

type LevelData = { tag: string; age: string; items: string[] }
type Props = {
	data: {
		title: string
		subtitle: string
		level1: LevelData
		level2: LevelData
	}
}

const { data } = Astro.props
---

<Section id="two-levels" padding="both">
	<Row>
		<Col span="12" align="center">
			<h2 set:html={data.title} />
			<p class="text-lg pb-8">{data.subtitle}</p>
		</Col>
	</Row>
	<Row>
		<Col span="6">
			<div class="rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 h-full bg-white dark:bg-neutral-800">
				<span class="inline-block rounded-full bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 px-3 py-1 text-sm font-semibold mb-4">{data.level1.tag}</span>
				<h3 class="text-xl font-bold mb-3">{data.level1.age}</h3>
				<ul class="space-y-2 text-neutral-600 dark:text-neutral-300">
					{data.level1.items.map((item) => <li>{item}</li>)}
				</ul>
				<div class="mt-6 rounded-lg overflow-hidden">
					<Image src={logicImg} alt="Child using PrimaSTEM on a grid map" class="w-full" format="webp" />
				</div>
			</div>
		</Col>
		<Col span="6">
			<div class="rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 h-full bg-white dark:bg-neutral-800">
				<span class="inline-block rounded-full bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 px-3 py-1 text-sm font-semibold mb-4">{data.level2.tag}</span>
				<h3 class="text-xl font-bold mb-3">{data.level2.age}</h3>
				<ul class="space-y-2 text-neutral-600 dark:text-neutral-300">
					{data.level2.items.map((item) => <li>{item}</li>)}
				</ul>
				<div class="mt-6 rounded-lg overflow-hidden">
					<Image src={mathImg} alt="Robot drawing a spiral on paper" class="w-full" format="webp" />
				</div>
			</div>
		</Col>
	</Row>
</Section>
