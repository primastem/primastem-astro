---
// Newsletter V1 — Two columns: text left, form right
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
---

<Section id="newsletter-v1" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="5" align="start">
			<h2>Stay <strong>updated</strong></h2>
			<p class="text-lg">No more than once a month — project news and offers.</p>
		</Col>
		<Col span="1" />
		<Col span="6">
			<div class="ml-embedded" data-form="jdJlRe"></div>
		</Col>
	</Row>
</Section>
