---
// Maps Compatibility Section — using TextImage component
import TextImage from '../basic/TextImage.astro'

import mapsImg from '../../../assets/map-beebot.jpg'

type Props = {
	data: {
		title: string
		text: string
	}
}

const { data } = Astro.props
---

<TextImage
	id="maps-v2"
	title={data.title}
	text={data.text}
	image={mapsImg}
	imagePosition="right"
	classes=""
/>
