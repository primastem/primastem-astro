---
// Drawing Section — Row of 5 images centered
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'

const drawings = ['square', 'pentagon', 'star', 'spiral', 'heart']
---

<Section id="drawing" padding="both">
	<Row>
		<Col span="12" align="center">
			<h2>The robot draws what <strong>the child programs</strong></h2>
			<p class="text-lg pb-8">These are not illustrations. The robot drew them following a child's program.</p>
		</Col>
	</Row>
	<Row>
		<Col span="1" />
		{drawings.map((name) => (
			<Col span="2" spanMobile="4" align="center">
				<div class="rounded-lg bg-neutral-100 dark:bg-neutral-700 aspect-square flex items-center justify-center text-neutral-400 mb-2">
					<span class="text-xs">drawing-{name}.png</span>
				</div>
				<p class="text-sm text-neutral-500 dark:text-neutral-400 capitalize">{name}</p>
			</Col>
		))}
		<Col span="1" />
	</Row>
	<Row>
		<Col span="12" align="center">
			<p class="text-base text-neutral-500 dark:text-neutral-400 pt-6"><code>Forward 50, Right 144, Repeat 5</code> = a star.</p>
		</Col>
	</Row>
</Section>
