---
// Drawing Section — Row of images centered
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Image } from 'astro:assets'

import pentagonImg from '../../../assets/drawings/drawing-pentagon.png'
import starImg from '../../../assets/drawings/drawing-star.png'
import spiralImg from '../../../assets/drawings/drawing-spiral-shape.png'
import heartImg from '../../../assets/drawings/drawing-heart.png'

type Props = {
	data: {
		title: string
		subtitle: string
		drawings: { name: string }[]
		example: string
	}
}

const { data } = Astro.props

// Image map keyed by name. Only names in this map will render with an image.
const imageMap: Record<string, ImageMetadata> = {
	Pentagon: pentagonImg,
	Star: starImg,
	Spiral: spiralImg,
	Heart: heartImg,
}
const drawingsWithImages = data.drawings
	.filter((d) => imageMap[d.name])
	.map((d) => ({ name: d.name, image: imageMap[d.name] }))
---

<Section id="drawing" padding="both" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="12" align="center">
			<h2 set:html={data.title} />
			<p class="text-lg pb-8" set:html={data.subtitle} />
		</Col>
	</Row>
	<div class="flex flex-wrap justify-center gap-6 px-4">
		{drawingsWithImages.map((item) => (
			<div class="flex flex-col items-center">
				<div class="w-[200px] h-[200px] flex items-center justify-center rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 mb-2">
					<Image
						src={item.image}
						alt={`Robot drawing: ${item.name}`}
						class="max-w-[180px] max-h-[180px] object-contain"
						format="webp"
						width={200}
					/>
				</div>
				<p class="text-sm text-neutral-500 dark:text-neutral-400 text-center">{item.name}</p>
			</div>
		))}
	</div>
	<Row>
		<Col span="12" align="center">
			<p class="text-base text-neutral-500 dark:text-neutral-400 pt-6"><code>{data.example}</code></p>
		</Col>
	</Row>
</Section>
