---
// Contact Form for PrimaSTEM with Netlify Forms
import Card from '../../ui/cards/partials/Card.astro'
import CardBody from '../../ui/cards/partials/CardBody.astro'
import FormField from '../../ui/forms/partials/FormField.astro'
import InputField from '../../ui/forms/form-elements/InputField.astro'
import TextArea from '../../ui/forms/form-elements/TextArea.astro'
import Button from '../../ui/Button.astro'

type Props = {
	classes?: string
}
const { classes } = Astro.props
---

<Card classes={classes}>
	<CardBody>
		<form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
			<input type="hidden" name="form-name" value="contact" />
			<p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
			<h2 class="text-2xl">Get in Touch</h2>
			<FormField>
				<InputField type="text" id="name" label="Name" required />
				<InputField type="text" id="organization" label="Organization" />
			</FormField>
			<FormField>
				<InputField type="email" id="email" label="Email" required />
			</FormField>
			<FormField>
				<InputField type="text" id="country" label="Country" required />
			</FormField>
			<FormField><TextArea id="message" label="Your Message" required /></FormField>
			<Button style="primary" type="submit">Send</Button>
		</form>
	</CardBody>
</Card>
