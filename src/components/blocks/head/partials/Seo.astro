---
// SEO Component
// ------------
// Description: A component to add SEO meta tags to the page.

import { languages, defaultLang } from '../../../../i18n/languages'

type Props = {
	title?: string
	description?: string
	ogImage?: string
	canonical?: boolean
	noindex?: boolean
}

const { title, description, ogImage, canonical, noindex } = Astro.props

// Absolute URL for social images (LinkedIn / WhatsApp unfurlers require absolute)
const ogImageAbs = new URL(ogImage ?? '/og.jpg', Astro.site ?? 'https://primastem.com').toString()

// Build hreflang alternate links
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://primastem.com'
const currentPath = Astro.url.pathname
const langCodes = Object.keys(languages) as (keyof typeof languages)[]

let basePath = currentPath
for (const code of langCodes) {
	if (code === defaultLang) continue
	if (currentPath === `/${code}` || currentPath === `/${code}/`) { basePath = '/'; break }
	if (currentPath.startsWith(`/${code}/`)) { basePath = currentPath.substring(code.length + 1); break }
}

const hreflangLinks = langCodes.map((code) => ({
	hreflang: code,
	href: code === defaultLang
		? `${siteUrl}${basePath}`
		: `${siteUrl}/${code}${basePath === '/' ? '/' : basePath}`
}))
---

<Fragment>
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta property="og:type" content="website" />
	<meta property="og:url" content={Astro.url} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={ogImageAbs} />
	<meta property="twitter:card" content="summary_large_image" />
	<meta property="twitter:url" content={Astro.url} />
	<meta property="twitter:title" content={title} />
	<meta property="twitter:description" content={description} />
	<meta property="twitter:image" content={ogImageAbs} />
	{canonical && <link rel="canonical" href={Astro.url} />}
	{noindex && <meta name="robots" content="noindex,nofollow" />}
	{hreflangLinks.map((link) => (
		<link rel="alternate" hreflang={link.hreflang} href={link.href} />
	))}
	<link rel="alternate" hreflang="x-default" href={`${siteUrl}${basePath}`} />
</Fragment>
