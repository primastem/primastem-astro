---
// Language Switcher — uses the theme's submenu pattern (header__menu-item / header__submenu)
// so the visual style matches the other nav dropdowns. Open/close handled by LocalScripts.

import { Icon } from 'astro-icon/components'
import { languages, defaultLang } from '../../i18n/languages'
import type { Lang } from '../../i18n/languages'

const langCodes = Object.keys(languages) as Lang[]
const currentPath = Astro.url.pathname

// Detect current locale from URL prefix
let currentLocale: Lang = defaultLang
for (const code of langCodes) {
	if (code === defaultLang) continue
	if (currentPath === `/${code}` || currentPath === `/${code}/` || currentPath.startsWith(`/${code}/`)) {
		currentLocale = code
		break
	}
}

// Strip locale prefix to get base path (relative to default locale)
let basePath = currentPath
if (currentLocale !== defaultLang) {
	if (currentPath === `/${currentLocale}` || currentPath === `/${currentLocale}/`) {
		basePath = '/'
	} else if (currentPath.startsWith(`/${currentLocale}/`)) {
		basePath = currentPath.substring(currentLocale.length + 1)
	}
}

// Build URL for each locale at same page
function urlFor(target: Lang): string {
	if (target === defaultLang) return basePath
	return `/${target}${basePath === '/' ? '/' : basePath}`
}
---

<li role="none" class="header__menu-item">
	<span role="menuitem" class="header__menu-link uppercase tracking-wider text-sm" aria-haspopup="true">
		{currentLocale}
		<Icon name="chevron-down" class="header__menu-chevron" />
	</span>
	<ul class="header__submenu">
		{
			langCodes.map((code) => (
				<li role="none" class="header__submenu-item">
					<a
						href={urlFor(code)}
						role="menuitem"
						class:list={['header__menu-link', { active: code === currentLocale }]}
					>
						{languages[code].name}
					</a>
				</li>
			))
		}
	</ul>
</li>
